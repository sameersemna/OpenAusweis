{
  "name": "@openausweis/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port ${OPENAUSWEIS_DESKTOP_PORT:-1420}",
    "build": "tsc -b && vite build",
    "lint": "echo \"No linter configured yet\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "tauri:dev": "npx tauri dev",
    "tauri:dev:snap-safe": "env -u GTK_EXE_PREFIX -u GTK_PATH -u GIO_MODULE_DIR -u GTK_IM_MODULE_FILE -u LOCPATH -u LD_LIBRARY_PATH -u PKG_CONFIG_PATH CARGO_BUILD_JOBS=1 npx tauri dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^4.1.5"
  }
}
