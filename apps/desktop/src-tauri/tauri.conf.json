{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAusweis",
  "version": "0.1.0",
  "identifier": "org.openausweis.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @openausweis/desktop",
    "beforeBuildCommand": "npm run build --workspace @openausweis/desktop",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png"
    },
    "windows": [
      {
        "title": "OpenAusweis",
        "width": 980,
        "height": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
