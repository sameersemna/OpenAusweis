{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @openausweis/desktop",
    "beforeBuildCommand": "npm run build --workspace @openausweis/desktop",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "OpenAusweis",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "org.openausweis.desktop"
    },
    "windows": [
      {
        "title": "OpenAusweis",
        "width": 980,
        "height": 680,
        "resizable": true
      }
    ]
  }
}
