{
  "manifest_version": 2,
  "name": "OpenAusweis Browser Connector",
  "version": "0.1.0",
  "description": "Connects websites to OpenAusweis native Linux daemon.",
  "permissions": ["nativeMessaging", "storage", "activeTab", "https://*/*", "http://localhost/*"],
  "background": {
    "scripts": ["src/background.v2-loader.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "OpenAusweis",
    "default_popup": "src/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "openausweis-browser@openausweis.org",
      "strict_min_version": "109.0"
    }
  }
}
